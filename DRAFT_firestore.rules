rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'saiedalmahdi31@gmail.com' && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Portfolio
    match /portfolio/{projectId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(projectId);
    }

    // Services
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(serviceId);
    }
    
    // Packages
    match /packages/{packageId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(packageId);
    }

    // Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(settingId);
    }
  }
}
